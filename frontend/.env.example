# Frontend build-time configuration (Vite).
# Copy to `frontend/.env` and fill in the deployed API endpoints.
#
# After `deploy.sh` completes, the REST and WebSocket API URLs are printed in
# the CDK stack outputs and by scripts/post-deploy.sh. Paste them here.
#
# If unset, the app falls back to placeholder URLs (YOUR-API-ID...) that will
# not work against a real backend — set these before building for production.

VITE_API_URL=https://YOUR-API-ID.execute-api.us-east-1.amazonaws.com/dev
VITE_WS_URL=wss://YOUR-WS-API-ID.execute-api.us-east-1.amazonaws.com/dev
