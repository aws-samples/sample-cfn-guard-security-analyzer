# CloudFormation Guard Security Analyzer — environment configuration template
# Copy to .env and fill in values for local development.

# AWS account and region for CDK deployment
CDK_DEFAULT_ACCOUNT=111111111111
CDK_DEFAULT_REGION=us-east-1

# Environment name: dev, staging, or prod
CDK_ENVIRONMENT=dev

# Bedrock model — defaults to Opus 4.7 if unset.
# Pick any Bedrock-enabled model in your account/region. Examples:
#   us.anthropic.claude-opus-4-7              (default — highest quality)
#   us.anthropic.claude-sonnet-4-6            (cheaper, similar tool-use quality)
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0
# Required: enable model access in Bedrock console for your chosen model.
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-7

# AgentCore runtime ARNs — populated automatically after `scripts/deploy-agents.sh`
SECURITY_ANALYZER_AGENT_ARN=
CRAWLER_AGENT_ARN=
PROPERTY_ANALYZER_AGENT_ARN=
GUARD_RULE_AGENT_ARN=

# CORS allowlist for the API. Comma-separated origins. Use the deployed CloudFront URL.
CORS_ORIGINS=http://localhost:5173
