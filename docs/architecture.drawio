        <mxCell id="e_orch_crawler" value="discover" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#9467BD;strokeWidth=2;endArrow=classic;endFill=1;fontColor=#9467BD;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="orch" target="crawler">
