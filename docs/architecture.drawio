        <mxCell id="e_inv_prop" value="per-property" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#555555;endArrow=classic;endFill=1;fontColor=#555555;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="invoker" target="prop">
          <mxGeometry relative="1" as="geometry">
