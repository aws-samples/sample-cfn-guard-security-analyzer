# AgentCore CLI local state (per-developer, regenerated by `agentcore configure`)
agents/.bedrock_agentcore/
agents/.bedrock_agentcore.yaml
agents/.bedrock_agentcore.yaml.bak.*

# Local conversation export (not part of the sample)
cfn_analyzer.txt
